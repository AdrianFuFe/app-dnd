# Copy this file to `.env` for local development.
# Use a dedicated Supabase project for local day-to-day work.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Required only for server-only admin or maintenance paths.
# Do not expose this value to the browser or commit a real key.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails that are allowed to receive the admin role
# through local operator tooling. Keep this list short and intentional.
ADMIN_ALLOWLIST_EMAILS=

# Used by Playwright to switch the app into the in-memory mock mode.
# This bypasses live Supabase auth and data entirely.
# Leave unset for normal local development.
APP_E2E=false
